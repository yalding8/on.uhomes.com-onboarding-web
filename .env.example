# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=your-project-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# [DEPRECATED] OpenSign — kept for legacy contracts only. New contracts use DocuSign.
OPENSIGN_WEBHOOK_SECRET=your-opensign-webhook-secret

# DocuSign eSignature (JWT Grant)
DOCUSIGN_CLIENT_ID=your-integration-key
DOCUSIGN_USER_ID=your-user-id
DOCUSIGN_ACCOUNT_ID=your-account-id
DOCUSIGN_PRIVATE_KEY=base64-encoded-rsa-private-key
DOCUSIGN_AUTH_SERVER=account-d.docusign.com
DOCUSIGN_TEMPLATE_ID=your-template-id
DOCUSIGN_WEBHOOK_SECRET=your-hmac-secret

# App URL (used for DocuSign webhook callback)
NEXT_PUBLIC_APP_URL=https://on-uhomes-com-onboarding-web.vercel.app
